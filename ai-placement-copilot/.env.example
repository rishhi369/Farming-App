APP_ENV=development
APP_NAME=AI Placement Copilot
LOG_LEVEL=INFO
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/api/v1/ws
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CLERK_JWKS_URL=
DATABASE_URL=postgresql+asyncpg://placement:placement@postgres:5432/placement_copilot
REDIS_URL=redis://redis:6379/0
CHROMA_PERSIST_DIR=/app/storage/chroma
UPLOAD_DIR=/app/storage/uploads
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
ENABLE_REAL_LLM=false
ENABLE_CREWAI=false
ENABLE_SEMANTIC_CACHE=true
RATE_LIMIT_PER_MINUTE=90

